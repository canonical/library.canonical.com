# =========================
# Flask Application Settings
# =========================
PORT=8051
DEVEL=True
FLASK_DEBUG=true
SECRET_KEY=your_secret_key_here

# =========================
# OIDC Authentication
# =========================
# See OIDC_SETUP.md for detailed configuration instructions
OIDC_ISSUER=https://login.staging.canonical.com
OIDC_CLIENT_ID=your_client_id_here
OIDC_CLIENT_SECRET=your_client_secret_here
OIDC_SCOPES=openid email profile
# Team membership required for access (Launchpad team name)
OPENID_LAUNCHPAD_TEAM=canonical-content-people

# =========================
# Google Drive Configuration
# =========================
# Shared Drive ID
TARGET_DRIVE=0ABG0Z5eOlOvhUk9PVA
# Root folder name in Drive
ROOT_FOLDER=library
# URL spreadsheet document ID for redirects
URL_FILE=16mTPcMn9hxjgra62ArjL6sTg75iKiqsdN99vtmrlyLg
# Default template document ID
DEFAULT_DOC=1YxnWy94YrNnraf1OAxXfIAbL677nNjvb-AWp1TaxU9s
# Drafts folder ID
DRAFT_FOLDER=1cI2ClDWDzv3osp0Adn0w3Y7zJJ5h08ua

# =========================
# Service Account Credentials
# =========================
# Extract these from your Google Cloud Service Account JSON file
# See OIDC_SETUP.md for instructions on creating Service Account
PROJECT_ID=your-project-id
PRIVATE_KEY_ID=your-private-key-id
PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nYour-Private-Key-Here\n-----END PRIVATE KEY-----\n"
CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
CLIENT_ID=123456789
CLIENT__X509_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/your-service-account%40your-project.iam.gserviceaccount.com

# =========================
# Email Notification Settings
# =========================
# SMTP server configuration for sending notification emails
# For Gmail, use smtp.gmail.com with App Password
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587  # Use 587 for STARTTLS, 465 for SSL
SMTP_USER=your-email@canonical.com
SMTP_PASSWORD=your-app-password-here  # For Gmail: Generate at https://myaccount.google.com/apppasswords
EMAIL_FROM=library-notifications@canonical.com

# Optional: Fallback email recipients for system notifications
NOTIFICATION_RECIPIENTS=admin@canonical.com

# =========================
# Database Configuration
# =========================
# Redis cache (optional, uses SimpleCache if not set)
REDIS_DB_CONNECT_STRING=redis://host.docker.internal:6379

# PostgreSQL database (optional, enables document caching and analytics)
POSTGRESQL_DB_CONNECT_STRING=postgresql+psycopg2://library_user:password@host.docker.internal:5432/library_dev

# =========================
# OpenSearch Configuration
# =========================
# URL to OpenSearch cluster
OPENSEARCH_URL=https://your-opensearch-cluster:9200
# Basic auth credentials
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=your-opensearch-password
# Index name for documents
OPENSEARCH_INDEX=library-docs
# Default search operator (and|or)
OPENSEARCH_DEFAULT_OPERATOR=or
# Optional: TLS CA certificate (PEM format or base64)
# OPENSEARCH_TLS_CA="-----BEGIN CERTIFICATE-----\n...\n-----END CERTIFICATE-----\n"

# =========================
# Sentry Error Tracking
# =========================
# Optional: Sentry DSN for error tracking
# SENTRY_DSN_SDK=https://your-sentry-dsn@sentry.io/project-id

# =========================
# Webhook Configuration (Future)
# =========================
# Google Cloud Pub/Sub topic for Drive webhooks
# PUBSUB_TOPIC=projects/your-project-id/topics/drive-events
# PUBSUB_SUBSCRIPTION=drive-events-sub

# =========================
# Scheduler Configuration
# =========================
# Number of worker threads for document ingestion (default: 10)
INGEST_WORKERS=10
